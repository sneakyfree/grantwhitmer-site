# Always revalidate document + code so deploys show up immediately (no stale cache).
/*
  Cache-Control: public, max-age=0, must-revalidate
/css/*
  Cache-Control: public, max-age=0, must-revalidate
/js/*
  Cache-Control: public, max-age=0, must-revalidate

# Static media (images, covers, fonts) can cache long — filenames are stable.
/assets/*
  Cache-Control: public, max-age=2592000

# Utility pages stay out of search results.
/thanks.html
  X-Robots-Tag: noindex
/404.html
  X-Robots-Tag: noindex
/admin
  X-Robots-Tag: noindex, nofollow
/admin/*
  X-Robots-Tag: noindex, nofollow
